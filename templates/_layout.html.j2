{# Base layout shared by every page. The generated *.html files in dist/ are
   built from this by build.py and must NOT be hand-edited. #}
<!doctype html>
<html lang="en" data-build="{{ build_fp }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}{{ site.title }}{% endblock %}</title>
<meta name="description" content="{% block description %}{{ site.description }}{% endblock %}">
{% block head_extra %}{% endblock %}
<script>
  // Apply the saved theme before first paint to avoid a flash. Light is the
  // default (no attribute); only an explicit "dark" choice is applied.
  (function () {
    try {
      if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      }
    } catch (e) {}
  })();
</script>
<link rel="stylesheet" href="/styles.css?v={{ css_version }}">
<script>
  // Pick a random emoji from the pool (site.yaml `favicons:`) on each load and
  // render it as an inline-SVG favicon: no asset files, no extra requests.
  (function () {
    var icons = {{ favicons | tojson }};
    if (!icons || !icons.length) return;
    var emoji = icons[Math.floor(Math.random() * icons.length)];
    var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">'
      + '<text x="50" y="54" font-size="78" text-anchor="middle" '
      + 'dominant-baseline="central">' + emoji + '</text></svg>';
    var link = document.querySelector('link[rel~="icon"]') || document.createElement('link');
    link.setAttribute('rel', 'icon');
    link.setAttribute('href', 'data:image/svg+xml,' + encodeURIComponent(svg));
    document.head.appendChild(link);
  })();
</script>
{% if page.interactive %}
<!-- Interactive demo kit (loaded only on chapters that opt in). -->
<script type="module" src="/static/demo-kit/kit.js?v={{ build_fp }}"></script>
{% endif %}
</head>
<body>
<div class="progress-track" aria-hidden="true"><div class="progress-bar" id="progress-bar"></div></div>
<main>
{% block topbar %}{% endblock %}
  <header class="masthead">
    {% if site.eyebrow %}<p class="eyebrow">{{ site.eyebrow }}</p>{% endif %}
    <div class="identity-head">
      <h1><a class="name-link" href="/" title="{{ site.title }}">{{ site.title }}</a></h1>
      <button class="head-tool theme-toggle" type="button" aria-label="Switch to dark theme" title="Toggle light / dark theme">
        <svg class="icon-moon" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8z"/>
        </svg>
        <svg class="icon-sun" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2"/>
          <path d="M12 2.5v2.2M12 19.3v2.2M4.5 4.5l1.6 1.6M17.9 17.9l1.6 1.6M2.5 12h2.2M19.3 12h2.2M4.5 19.5l1.6-1.6M17.9 6.1l1.6-1.6"/>
        </svg>
      </button>
    </div>
    {% if site.tagline %}<p class="tagline">{{ site.tagline }}</p>{% endif %}
  </header>

{% block content %}{% endblock %}

{% block footer %}
  <footer class="site-footer">© {{ site.footer }}</footer>
{% endblock %}
</main>
<script>
  // Theme toggle: flips data-theme on <html> and remembers the choice.
  (function () {
    var btn = document.querySelector('.theme-toggle');
    if (!btn) return;
    var root = document.documentElement;
    function sync() {
      var dark = root.getAttribute('data-theme') === 'dark';
      btn.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
      btn.setAttribute('aria-pressed', String(dark));
    }
    sync();
    btn.addEventListener('click', function () {
      var dark = root.getAttribute('data-theme') === 'dark';
      if (dark) root.removeAttribute('data-theme');
      else root.setAttribute('data-theme', 'dark');
      try { localStorage.setItem('theme', dark ? 'light' : 'dark'); } catch (e) {}
      window.dispatchEvent(new CustomEvent('themechange'));
      sync();
    });
  })();
</script>
<script>
  // Reading progress: fill the top bar in proportion to scroll depth.
  (function () {
    var bar = document.getElementById('progress-bar');
    if (!bar) return;
    function update() {
      var h = document.documentElement;
      var max = h.scrollHeight - h.clientHeight;
      var pct = max > 0 ? (h.scrollTop || document.body.scrollTop) / max : 0;
      bar.style.width = (pct * 100).toFixed(1) + '%';
    }
    update();
    window.addEventListener('scroll', update, { passive: true });
    window.addEventListener('resize', update);
  })();
</script>
{% block scripts %}{% endblock %}
</body>
</html>
